
@{
    ViewBag.Title = "LienHe";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<!-- Phần Content -->
<main class="LienHe">
    <!-- Thông tin liên hệ -->
    <section class="ThongTinLienHe">
        <div class="container">
            <div class="row text-center">
                <div class="col-4">
                    <i class="fa fa-phone fa-2x"></i>
                    <h4>Hotline</h4>
                    <p>076 299 0875</p>
                </div>
                <div class="col-4">
                    <i class="fa fa-envelope fa-2x"></i>
                    <h4>Email</h4>
                    <p>SchoolSuppliesStore@gmail.com</p>
                </div>
                <div class="col-4">
                    <i class="fa fa-location-dot fa-2x"></i>
                    <h4>Địa chỉ</h4>
                    <p>Số 243 Trần Văn Giàu, Phường Hòa Thuận, Tỉnh Vĩnh Long</p>
                </div>
            </div>
        </div>
    </section>
    <!-- Form liên hệ -->
    <section class="FormLienHe">
        <hr class="hr" />
        <div class="container">
            <h2 class="text-center">GỬI THÔNG TIN</h2>
            <p class="text-center">Bạn có bất kỳ khó khăn gì cần liên hệ vui lòng gửi qua form tại đây chúng tôi sẽ liên hệ bạn sau nhé!</p>
            <form action="#" method="post" class="LienHeForm">
                <div class="row">
                    <div class="col-6">
                        <label for="hoten">Họ và tên *</label>
                        <input type="text" id="hoten" name="hoten" required />
                    </div>
                    <div class="col-6">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required />
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <label for="noidung">Nội dung *</label>
                        <textarea id="noidung" name="noidung" rows="5" required></textarea>
                    </div>
                </div>
                <div class="text-center">
                    <button type="submit" class="btn-gui">Gửi</button>
                </div>
            </form>
        </div>
        <hr class="hr" />
        <p class="text-center camon">Cảm ơn bạn đã liên hệ. Chúng tôi sẽ phản hồi lại bạn ngay!</p>
    </section>
</main>

