
@model IEnumerable<StationeryWebsite.Models.Category>

@{
    ViewBag.Title = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout.cshtml";
}

<main>
    <div class="container-fluid px-4">
        <h1 class="mt-4">Quản lý danh mục</h1>
       
        <ol class="breadcrumb mb-4">
            <li class="breadcrumb-item"><a href="index.html">Trang chủ</a></li>
            <li class="breadcrumb-item active">Quản lý danh mục</li>
        </ol>
        @*<div class="card mb-4">
            <div class="card-body">
                DataTables is a third party plugin that is used to generate the demo table below. For more information about DataTables, please visit the
                <a target="_blank" href="https://datatables.net/">official DataTables documentation</a>
                .
            </div>
        </div>*@
    <div class="card mb-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">

                <!-- Tiêu đề -->
                <h5 class="mb-0 fw-semibold">
                    
                    Danh sách danh mục
                </h5>

                <!-- Nút thêm -->
                <a href="@Url.Action("Create", "Categories", new { area = "Admin" })"
                   class="btn btn-primary d-flex align-items-center gap-2 px-3">
                    <i class="fa fa-plus"></i>
                    <span>Thêm sản phẩm</span>
                </a>

            </div>
        </div>
        
        <div class="card-body">
            <table id="datatablesSimple">
                <thead>
                    <tr>
                        <th>
                            Tên danh mục
                        </th>
                        <th>
                            Hình ảnh
                        </th>
                        <th>
                            Ghi chú
                        </th>
                        <th class="text-center" width="200px">Chức năng</th>
                    </tr>
                </thead>
                <tfoot>
                    <tr>
                        <th>
                            Tên danh mục
                        </th>
                        <th>
                            Hình ảnh
                        </th>
                        <th>
                            Ghi chú
                        </th>
                        <th class="text-center" width="200px">Chức năng</th>
                    </tr>
                </tfoot>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var i = ((ViewBag.Page - 1) * ViewBag.PageSize) + 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.name)
                                </td>

                                <td>
                                    <img src="@item.image" width="100" class="img-thumbnail" />
                                </td>

                                <td>
                                    @Html.DisplayFor(modelItem => item.note)
                                </td>

                                <td class="text-center">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.category_id }, new { @class = "btn btn-warning btn-sm" })
                                    @Html.ActionLink("Details", "Details", new { id = item.category_id }, new { @class = "btn btn-info btn-sm" })
                                    @Html.ActionLink("Delete", "Delete", new { id = item.category_id }, new { @class = "btn btn-danger btn-sm" })
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">Không có bản ghi nào </td>
                        </tr>
                    }




                </tbody>
            </table>

        </div>
    </div>
    </div>
</main>